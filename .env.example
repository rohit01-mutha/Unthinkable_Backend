# Database Configuration
# Replace with your actual PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/last_mile_delivery?schema=public"

# Auth Secret
JWT_SECRET="your_jwt_signing_secret_key"

# Email Integration (SendGrid, Resend, etc.)
EMAIL_SERVICE_API_KEY="your_email_service_api_key_here"

# Server configuration
PORT=5000

# CORS Allowed Origins
# Deployed frontend domain (e.g. https://your-app.vercel.app) or localhost for development
FRONTEND_URL="http://localhost:5173"
